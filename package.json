{
  "name": "polemic",
  "version": "1.0.0",
  "description": "Open-Source LaTeX Editor with Electron, React, and TypeScript",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --project tsconfig.main.json",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@tiptap/extension-code-block": "^2.4.0",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/pm": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "electron": "^31.0.0",
    "katex": "^0.16.10",
    "latex.js": "^0.12.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.2.1",
    "react-syntax-highlighter": "^15.5.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron/remote": "^2.0.10",
    "@tailwindcss/postcss": "^4.0.0-alpha.14",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron-builder": "^24.9.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.0.0-alpha.14",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "latex",
    "editor",
    "electron",
    "react",
    "typescript",
    "katex",
    "tiptap"
  ],
  "author": "dwarsbit",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dwarsbit/polemic/issues"
  },
  "homepage": "https://github.com/dwarsbit/polemic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dwarsbit/polemic.git"
  }
}
